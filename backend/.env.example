# --- LLM (OpenRouter) ---
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model used for RAG answers and the agent. Any OpenRouter model works.
# Good free options:
#   meta-llama/llama-3.3-70b-instruct:free   (default - strong at JSON + grounding)
#   deepseek/deepseek-chat-v3-0324:free
#   google/gemini-2.0-flash-exp:free
LLM_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free

# Optional - shown on your OpenRouter dashboard, safe to leave as is
APP_URL=http://localhost:3000
APP_NAME=Smart Review Intelligence

# --- Sentiment engine (Part 1) ---
# "vader"  -> fast, offline, no key (default)
# "llm"    -> more accurate on tricky reviews, uses the LLM above (needs a key).
#             Falls back to VADER automatically if a call fails.
SENTIMENT_BACKEND=vader

# --- Embeddings ---
# Backend: auto | sentence-transformers | fastembed
# "auto" uses sentence-transformers if installed, otherwise fastembed.
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Only retrieve reviews above this cosine similarity (0-1). Lower = more recall.
RETRIEVAL_THRESHOLD=0.35
RETRIEVAL_TOP_K=4

# --- Storage paths ---
DATABASE_URL=sqlite:///./reviews.db
FAISS_INDEX_PATH=./faiss_index.bin
AGENT_REPORT_PATH=./agent_report.json

# --- CORS ---
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:3000
